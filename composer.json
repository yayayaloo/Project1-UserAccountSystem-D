{
  "name": "user-account-management/project",
  "description": "User Account Management System built with Laravel.",
  "type": "project",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
